    },
    "sensor": {
      "temperature": { "name": "Temperature" },
      "humidity": { "name": "Humidity" },
      "pcb_temp": { "name": "PCB Temperature" },
      "water_level": { "name": "Water Level" },
      "pump_voltage": { "name": "Pump Voltage" },
      "pump_current": { "name": "Pump Current" },
      "pump_power": { "name": "Pump Power" },
      "light_schedule": { "name": "Light Schedule" },
      "pump_schedule": { "name": "Pump Schedule" }
    },
    "binary_sensor": {
      "water_low": { "name": "Water Low" },
      "over_temp": { "name": "Over Temp" }
    },
    "switch": {
      "light_schedule": { "name": "Light Schedule" },
      "pump_schedule": { "name": "Pump Schedule" }
    },
